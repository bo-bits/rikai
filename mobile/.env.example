# Copy to mobile/.env and restart the Expo dev server after changes.
# These are EXPO_PUBLIC_* so they're inlined into the client bundle — only put
# the publishable/anon key here, never the service-role/secret key.

# Local Supabase. iOS simulator can reach 127.0.0.1; on a physical device use
# your machine's LAN IP (e.g. http://192.168.1.20:55321) so the phone can reach it.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
